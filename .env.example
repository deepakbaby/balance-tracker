# Core System
ENVIRONMENT=production

# Balance Tracker Local Credentials
BALANCE_USER=deepak
BALANCE_PASSWORD=INSERT_PROD_PASSWORD_HERE
# Run `openssl rand -hex 32` to generate a strong session secret
BALANCE_SESSION_SECRET=INSERT_STRONG_RANDOM_SECRET_HERE

# Database URI (psycopg2 compatible)
DATABASE_URL=postgresql://deepak:YOUR_STRONG_PG_PASSWORD@localhost:5432/balance_db

# Network Boundaries (Should remain Localhost)
BALANCE_HOST=127.0.0.1
BALANCE_PORT=8787
# The hostname the PWA is served on natively by NGINX
BALANCE_ALLOWED_ORIGIN=https://balance.deepakbaby.in
